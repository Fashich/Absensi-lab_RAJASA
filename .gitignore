# Dependency directories
node_modules/
vendor/

# Build and distribution directories
/dist/
/build/
/public/build/
/webpack.mix.js

# Environment specific settings
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage
lib-cov/

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Temporary folders
tmp/
temp/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# PHP/Laravel specific
.phpunit.result.cache
.php_cs.cache
composer.lock

# Database files
*.sqlite
*.sqlite3

# IDE specific files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Backend specific ignores
backend/uploads/ # Image uploads folder (but keep the directory structure)
backend/config/database.php.bak # Backup of database config
backend/storage/logs/*

# Frontend specific ignores
frontend/node_modules/
frontend/build/
frontend/coverage/
.nyc_output/

# Local configuration files that might contain sensitive info
config/
*.key
*.pem
*.crt
*.cert

# Laravel specific (even though this isn't Laravel, some common ignores)
public/hot
storage/*/
!storage/.gitkeep
vendor/composer/installed.json