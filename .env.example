# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sistem_presensi_smk

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=86400

# Application Configuration
APP_NAME="Sistem Presensi SMK Rajasa"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/project_magang

# Email Configuration (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_ENCRYPTION=tls

# ESP32 API Key (for hardware integration)
ESP32_API_KEY=your_esp32_api_key_here

# Port Configuration
PORT=8000